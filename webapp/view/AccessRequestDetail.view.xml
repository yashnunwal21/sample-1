<mvc:View
    controllerName="com.sap.grc.sapgrcaccessmanagement.controller.AccessRequestDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">

    <Page id="AccessRequestDetailPage" title="Request Detail" showNavButton="true" navButtonPress="onNavBack" class="sapUiContentPadding">

        <VBox id="detailContent" class="grcDetailPage">
            <Panel headerText="Request Summary" class="grcDetailSection">
                <VBox class="sapUiSmallMargin">
                    <Title text="{detail>/requestNumber}" level="H3" class="sapUiTinyMarginBottom"/>
                    <Text text="{detail>/roleName}" class="sapUiTinyMarginBottom"/>
                    <ObjectStatus
                        text="{path: 'detail>/status', formatter: '.formatter.requestStatusText'}"
                        state="{path: 'detail>/status', formatter: '.formatter.statusState'}"
                        class="sapUiTinyMarginBottom"/>
                    <Text text="Requested by {detail>/requestorName} for {detail>/targetUserName}"/>
                    <Text text="Approver: {detail>/approverName}" visible="{= !!${detail>/approverName} }" class="grcFieldHelp sapUiTinyMarginTop"/>
                </VBox>
            </Panel>

            <Panel headerText="Workflow Progress" class="sapUiMediumMarginTop grcDetailSection">
                <Table
                    items="{detail>/workflowSteps}"
                    showSeparators="Inner"
                    fixedLayout="false"
                    class="grcWorkflowTable grcDetailWorkflowTable">
                    <columns>
                        <Column>
                            <Text text="Workflow Stage"/>
                        </Column>
                        <Column width="13rem" hAlign="Begin">
                            <Text text="Status"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{detail>title}" wrapping="true"/>
                                <ObjectStatus text="{detail>text}" state="{detail>state}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>

            <Panel headerText="Request Information" class="sapUiMediumMarginTop">
                <f:SimpleForm
                    id="detailForm"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="4"
                    labelSpanS="12"
                    columnsXL="2"
                    columnsL="2"
                    columnsM="1">

                    <Label text="Current Status"/>
                    <ObjectStatus
                        text="{path: 'detail>/status', formatter: '.formatter.requestStatusText'}"
                        state="{path: 'detail>/status', formatter: '.formatter.statusState'}"/>

                    <Label text="Requested By"/>
                    <Text text="{detail>/requestorName}"/>

                    <Label text="Requested For"/>
                    <Text text="{detail>/targetUserName}"/>

                    <Label text="Employee / User Type"/>
                    <Text text="{detail>/targetType}"/>

                    <Label text="SAP Role"/>
                    <Text text="{detail>/roleName}"/>

                    <Label text="Business Justification"/>
                    <Text text="{detail>/businessJustification}" wrapping="true"/>

                    <Label text="Approver" visible="{= !!${detail>/approverName} }"/>
                    <Text text="{detail>/approverName}" visible="{= !!${detail>/approverName} }"/>

                    <Label text="Approval / Rejection Date" visible="{= !!${detail>/processedOn} }"/>
                    <Text text="{path: 'detail>/processedOn', formatter: '.formatter.formatDateTime'}" visible="{= !!${detail>/processedOn} }"/>

                    <Label text="Created On"/>
                    <Text text="{path: 'detail>/createdOn', formatter: '.formatter.formatDateTime'}"/>

                    <Label text="Last Updated"/>
                    <Text text="{path: 'detail>/updatedOn', formatter: '.formatter.formatDateTime'}"/>
                </f:SimpleForm>
            </Panel>

            <Panel headerText="Approval Comments" class="sapUiMediumMarginTop" visible="{= !!${detail>/managerComment} || !!${detail>/securityComment} }">
                <VBox>
                    <VBox visible="{= !!${detail>/managerComment} }" class="sapUiSmallMarginBottom">
                        <Label text="Manager Comment"/>
                        <Text text="{detail>/managerComment}" wrapping="true"/>
                    </VBox>
                    <VBox visible="{= !!${detail>/securityComment} }">
                        <Label text="SAP GRC Comment"/>
                        <Text text="{detail>/securityComment}" wrapping="true"/>
                    </VBox>
                </VBox>
            </Panel>

            <Panel headerText="Role Enablers" class="sapUiMediumMarginTop" visible="{= !!${detail>/selectedEnablers} }">
                <List items="{detail>/selectedEnablers}" noDataText="No role enabler values recorded">
                    <CustomListItem>
                        <VBox class="sapUiTinyMargin">
                            <ObjectIdentifier title="{detail>name}" text="{detail>subcategoryName}"/>
                            <List items="{detail>fields}" showSeparators="None">
                                <CustomListItem>
                                    <HBox class="grcStatusRow" justifyContent="SpaceBetween">
                                        <Text text="{detail>label}"/>
                                        <Text text="{detail>value}" textAlign="End"/>
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </VBox>
                    </CustomListItem>
                </List>
            </Panel>

            <VBox id="managerActionArea" visible="{actionView>/showManagerActions}" class="sapUiMediumMarginTop">
                <Title text="Manager Decision" level="H4" class="sapUiSmallMarginBottom"/>
                <TextArea id="managerCommentInput" value="{actionView>/managerComment}" rows="2" width="100%" placeholder="Add a comment (optional)"/>
                <HBox class="sapUiSmallMarginTop">
                    <Button text="Approve" type="Accept" press="onManagerApprove" class="sapUiTinyMarginEnd"/>
                    <Button text="Reject" type="Reject" press="onManagerReject"/>
                </HBox>
            </VBox>

            <VBox id="securityActionArea" visible="{actionView>/showSecurityActions}" class="sapUiMediumMarginTop">
                <Title text="Security Review Decision" level="H4" class="sapUiSmallMarginBottom"/>
                <TextArea id="securityCommentInput" value="{actionView>/securityComment}" rows="2" width="100%" placeholder="Add a comment (optional)"/>
                <HBox class="sapUiSmallMarginTop">
                    <Button text="Approve" type="Accept" press="onSecurityApprove" class="sapUiTinyMarginEnd"/>
                    <Button text="Reject" type="Reject" press="onSecurityReject"/>
                </HBox>
            </VBox>

            <VBox id="completeActionArea" visible="{actionView>/showCompleteAction}" class="sapUiMediumMarginTop">
                <Title text="Provisioning" level="H4" class="sapUiSmallMarginBottom"/>
                <Text text="Approved and awaiting provisioning in the target system." class="sapUiTinyMarginBottom"/>
                <TextArea id="completionCommentInput" value="{actionView>/completionComment}" rows="2" width="100%" placeholder="Add a completion note (optional)"/>
                <Button text="Mark as Provisioned" type="Emphasized" press="onCompleteProvisioning" class="sapUiSmallMarginTop"/>
            </VBox>

            <VBox id="withdrawActionArea" visible="{actionView>/showWithdrawAction}" class="sapUiMediumMarginTop">
                <Title text="Your Request" level="H4" class="sapUiSmallMarginBottom"/>
                <Text text="You can withdraw this request while it is still awaiting manager approval." class="sapUiTinyMarginBottom"/>
                <Button text="Withdraw Request" type="Reject" press="onWithdraw"/>
            </VBox>
        </VBox>

    </Page>

</mvc:View>
