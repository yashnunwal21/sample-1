<mvc:View
    controllerName="com.sap.grc.sapgrcaccessmanagement.controller.AccessRequestCreate"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">

    <Page id="AccessRequestCreatePage" title="Create Access Request" showNavButton="true" navButtonPress="onNavBack" class="sapUiContentPadding">
        <VBox class="grcRequestCreate">
            <Title text="New Access Request" level="H3" class="sapUiTinyMarginBottom"/>
            <Text text="Complete the request from employee details through role enablers before submitting." class="sapUiMediumMarginBottom"/>

            <Panel headerText="1. Employee Details" expandable="true" expanded="true" class="sapUiMediumMarginBottom">
                <SegmentedButton id="requesterTypeButton" selectedKey="{formView>/requesterType}" select="onRequesterTypeChange" class="sapUiSmallMarginBottom">
                    <items>
                        <SegmentedButtonItem key="MSIL" text="MSIL Employee"/>
                        <SegmentedButtonItem key="OUTSIDER" text="External / Non-MSIL"/>
                    </items>
                </SegmentedButton>

                <VBox visible="{= ${formView>/requesterType} === 'MSIL' }">
                    <RadioButtonGroup
                        id="forSelfGroup"
                        selectedIndex="{formView>/forSelfIndex}"
                        select="onRequesterDetailsChange"
                        columns="2"
                        class="sapUiTinyMarginBottom">
                        <buttons>
                            <RadioButton text="Self"/>
                            <RadioButton text="Another Employee"/>
                        </buttons>
                    </RadioButtonGroup>

                    <f:SimpleForm
                        editable="false"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsXL="2"
                        columnsL="2"
                        columnsM="1"
                        visible="{= ${formView>/forSelfIndex} === 0 }">
                        <Label text="Staff ID"/>
                        <Text text="{formView>/currentEmployee/employeeId}"/>
                        <Label text="Employee Name"/>
                        <Text text="{formView>/currentEmployee/fullName}"/>
                        <Label text="Department"/>
                        <Text text="{formView>/currentEmployee/department}"/>
                        <Label text="Designation"/>
                        <Text text="{formView>/currentEmployee/designation}"/>
                        <Label text="Plant"/>
                        <Text text="{formView>/currentEmployee/plant}"/>
                        <Label text="Manager"/>
                        <Text text="{formView>/currentEmployee/managerName}"/>
                        <Label text="Email"/>
                        <Text text="{formView>/currentEmployee/email}"/>
                        <Label text="Employment Type"/>
                        <ObjectStatus text="{formView>/currentEmployee/employmentType}" state="Information"/>
                    </f:SimpleForm>

                    <VBox visible="{= ${formView>/forSelfIndex} === 1 }">
                        <Label text="Staff ID" required="true"/>
                        <HBox class="sapUiTinyMarginBottom">
                            <Input
                                id="employeeIdInput"
                                value="{formView>/employeeIdInput}"
                                maxLength="6"
                                width="10rem"
                                placeholder="6-digit Staff ID"
                                class="sapUiTinyMarginEnd"/>
                            <Button text="Search Employee" press="onEmployeeLookup"/>
                        </HBox>
                        <MessageStrip
                            text="{formView>/employeeLookupError}"
                            type="Error"
                            showIcon="true"
                            visible="{= !!${formView>/employeeLookupError} }"
                            class="sapUiTinyMarginBottom"/>
                        <f:SimpleForm
                            editable="false"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="3"
                            labelSpanL="3"
                            labelSpanM="4"
                            labelSpanS="12"
                            columnsXL="2"
                            columnsL="2"
                            columnsM="1"
                            visible="{= !!${formView>/targetEmployee} }">
                            <Label text="Staff ID"/>
                            <Text text="{formView>/targetEmployee/employeeId}"/>
                            <Label text="Employee Name"/>
                            <Text text="{formView>/targetEmployee/fullName}"/>
                            <Label text="Department"/>
                            <Text text="{formView>/targetEmployee/department}"/>
                            <Label text="Designation"/>
                            <Text text="{formView>/targetEmployee/designation}"/>
                            <Label text="Plant"/>
                            <Text text="{formView>/targetEmployee/plant}"/>
                            <Label text="Manager"/>
                            <Text text="{formView>/targetEmployee/managerName}"/>
                            <Label text="Email"/>
                            <Text text="{formView>/targetEmployee/email}"/>
                            <Label text="Employment Type"/>
                            <ObjectStatus text="{formView>/targetEmployee/employmentType}" state="Information"/>
                        </f:SimpleForm>
                    </VBox>
                </VBox>

                <f:SimpleForm
                    id="outsiderForm"
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="4"
                    labelSpanS="12"
                    columnsXL="2"
                    columnsL="2"
                    columnsM="1"
                    visible="{= ${formView>/requesterType} === 'OUTSIDER' }">
                    <Label text="Full Name" required="true"/>
                    <Input value="{formView>/outsiderName}" liveChange="onRequesterDetailsChange"/>
                    <Label text="Organization / Company" required="true"/>
                    <Input value="{formView>/outsiderOrganization}" liveChange="onRequesterDetailsChange"/>
                    <Label text="Email" required="true"/>
                    <Input value="{formView>/outsiderEmail}" type="Email" liveChange="onRequesterDetailsChange"/>
                    <Label text="Mobile Number" required="true"/>
                    <Input value="{formView>/outsiderMobile}" type="Tel" liveChange="onRequesterDetailsChange"/>
                    <Label text="Purpose of Access" required="true"/>
                    <TextArea value="{formView>/outsiderPurpose}" rows="2" width="100%" liveChange="onRequesterDetailsChange"/>
                </f:SimpleForm>
            </Panel>

            <MessageStrip
                text="Selected for: {formView>/targetSummary}"
                type="Information"
                showIcon="true"
                visible="{= !!${formView>/targetSummary} }"
                class="sapUiMediumMarginBottom"/>

            <MessageStrip
                text="Complete valid requester details to continue to Business Area selection."
                type="Information"
                showIcon="true"
                visible="{= !${formView>/showConfigurationSteps} }"
                class="sapUiMediumMarginBottom"/>

            <Panel headerText="2. Business Area" expandable="true" expanded="true" class="sapUiMediumMarginBottom" visible="{formView>/showConfigurationSteps}">
                <VBox>
                    <Label text="Business Area" required="true"/>
                    <Select
                        id="businessAreaSelect"
                        width="24rem"
                        forceSelection="false"
                        selectedKey="{formView>/selectedBusinessAreaId}"
                        change="onBusinessAreaChange"
                        items="{formView>/businessAreas}">
                        <core:Item key="{formView>businessAreaId}" text="{formView>name}"/>
                    </Select>
                    <Text text="{formView>/selectedBusinessAreaDescription}" class="grcFieldHelp sapUiTinyMarginTop"/>
                </VBox>
            </Panel>

            <Panel headerText="3. Subcategory" expandable="true" expanded="true" class="sapUiMediumMarginBottom" visible="{= !!${formView>/selectedBusinessAreaId} }">
                <VBox>
                    <Label text="Subcategory" required="true"/>
                    <Select
                        id="subcategorySelect"
                        width="24rem"
                        forceSelection="false"
                        selectedKey="{formView>/selectedSubcategoryId}"
                        change="onSubcategoryChange"
                        items="{formView>/subcategories}">
                        <core:Item key="{formView>subcategoryId}" text="{formView>name}"/>
                    </Select>
                    <Text text="{formView>/selectedSubcategoryDescription}" class="grcFieldHelp sapUiTinyMarginTop"/>
                </VBox>
            </Panel>

            <Panel headerText="4. Role Selection" expandable="true" expanded="true" class="sapUiMediumMarginBottom" visible="{= !!${formView>/selectedSubcategoryId} }">
                <VBox>
                    <Label text="SAP Role" required="true"/>
                    <Select
                        id="roleSelect"
                        width="24rem"
                        forceSelection="false"
                        selectedKey="{formView>/selectedRoleId}"
                        change="onRoleChange"
                        items="{formView>/availableRoles}">
                        <core:Item key="{formView>roleId}" text="{formView>roleName}"/>
                    </Select>
                    <Text text="{formView>/selectedRoleDescription}" class="grcFieldHelp sapUiTinyMarginTop"/>
                </VBox>
            </Panel>

            <Panel
                id="requestDetailsPanel"
                headerText="5. Role Enablers"
                expandable="true"
                expanded="true"
                visible="{= !!${formView>/selectedRoleId} }"
                class="sapUiMediumMarginBottom">
                <VBox>
                    <Text text="Complete the role-specific fields for {formView>/selectedRoleName}." class="sapUiSmallMarginBottom"/>
                    <VBox id="dynamicFieldsBox" class="grcDynamicFieldList"/>
                </VBox>
            </Panel>

            <Panel headerText="6. Review &amp; Submit" expandable="true" expanded="true" visible="{= !!${formView>/selectedRoleId} }">
                <Text text="Review the selected employee, business area, subcategory, role, and enabler values before submitting."/>
            </Panel>
        </VBox>

        <footer>
            <Toolbar>
                <ToolbarSpacer/>
                <Button text="Cancel" press="onNavBack"/>
                <Button text="Submit Request" type="Emphasized" press="onSubmit" enabled="{= !!${formView>/selectedRoleId} }"/>
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
